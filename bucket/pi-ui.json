{
    "version": "0.13.0",
    "description": "Pi UI - keyboard-first desktop GUI for pi",
    "homepage": "https://github.com/hyperpuncher/pi-ui",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/hyperpuncher/pi-ui/releases/download/v0.13.0/pi-ui-windows-x64.msi#/dl.msi_",
            "hash": "8b55e4c2400eb3a5fb038dd855387ef5ad0da77ea8feb17a2c39f2afa3281fa1"
        }
    },
    "depends": "lessmsi",
    "pre_install": [
        "$stage = Join-Path $dir '_msi'",
        "New-Item -ItemType Directory -Path $stage -Force | Out-Null",
        "& lessmsi x \"$dir\\$fname\" ($stage + '\\')",
        "if ($LASTEXITCODE -ne 0) { throw 'Failed to extract the pi-ui MSI payload' }",
        "$payload = Get-ChildItem $stage -Filter 'payload.tar.zst' -File -Recurse | Select-Object -First 1",
        "if (-not $payload) { throw 'payload.tar.zst was not found in the pi-ui MSI' }",
        "Expand-7zipArchive -Path $payload.FullName -DestinationPath $dir -Removal",
        "if (-not (Test-Path \"$dir\\pi-ui\\pi-ui.exe\" -PathType Leaf)) { throw 'pi-ui.exe was not found after payload extraction' }",
        "Remove-Item $stage, \"$dir\\$fname\" -Recurse -Force"
    ],
    "bin": "pi-ui\\pi-ui.exe",
    "shortcuts": [
        [
            "pi-ui\\pi-ui.exe",
            "Pi UI"
        ]
    ],
    "checkver": {
        "github": "https://github.com/hyperpuncher/pi-ui"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hyperpuncher/pi-ui/releases/download/v$version/pi-ui-windows-x64.msi#/dl.msi_"
            }
        }
    },
    "notes": [
        "Pi UI is a keyboard-first desktop GUI for pi (pi.dev).",
        "Run with: pi-ui",
        "",
        "Keybinds:",
        "- Ctrl+K: command menu",
        "- Ctrl+O: new session",
        "- Ctrl+R: session picker",
        "- Ctrl+L: model picker",
        "- Alt+T: cycle thinking level",
        "- /: slash commands",
        "- @: file picker"
    ]
}
