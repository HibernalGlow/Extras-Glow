{
  "version": "0.10.1",
  "description": "Windows Explorer shell extension for showing cover thumbnails and preview-pane previews of archive and ebook files",
  "homepage": "https://github.com/citrussoda-com/ArcThumb",
  "license": "MIT OR Apache-2.0",
  "architecture": {
    "64bit": {
      "url": "https://github.com/citrussoda-com/ArcThumb/releases/download/v0.10.1/ArcThumb-Setup.exe",
      "hash": "sha256:e59797710baaec28c884d85607cc45a9e468280ef7fa99c832a0694ff307407d"
    }
  },
  "installer": {
    "script": [
      "Stop-Process -Name explorer -Force -ErrorAction SilentlyContinue",
      "Stop-Process -Name dllhost -Force -ErrorAction SilentlyContinue",
      "Stop-Process -Name prevhost -Force -ErrorAction SilentlyContinue",
      "Start-Process \"$dir\\$fname\" '/VERYSILENT','/SUPPRESSMSGBOXES','/NORESTART','/SP-' -Wait",
      "$installDir = Join-Path $env:LOCALAPPDATA 'Programs\\ArcThumb'",
      "if (Test-Path $installDir) {",
      "  Remove-Item \"$dir\\$fname\" -Force -ErrorAction SilentlyContinue",
      "}",
      "Start-Process explorer"
    ]
  },
  "uninstaller": {
    "script": [
      "Stop-Process -Name explorer -Force -ErrorAction SilentlyContinue",
      "Stop-Process -Name dllhost -Force -ErrorAction SilentlyContinue",
      "Stop-Process -Name prevhost -Force -ErrorAction SilentlyContinue",
      "$installDir = Join-Path $env:LOCALAPPDATA 'Programs\\ArcThumb'",
      "$uninstaller = Join-Path $installDir 'arcthumb-config.exe'",
      "if (Test-Path $uninstaller) { & $uninstaller '--uninstall' }",
      "Start-Process explorer"
    ]
  },
  "checkver": {
    "github": "citrussoda-com/ArcThumb"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/citrussoda-com/ArcThumb/releases/download/v$version/ArcThumb-Setup.exe"
      }
    }
  }
}
