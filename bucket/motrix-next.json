{
  "version": "3.8.9",
  "description": "Motrix Next - A full-featured download manager with browser extension support",
  "homepage": "https://github.com/AnInsomniacy/motrix-next",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.9/MotrixNext_3.8.9_x64-setup.exe",
      "hash": "92b0260e1b0ddae401a2c5054dd9bb54afc7f518f5b37a053fbbd17331dd73a9"
    }
  },
  "depends": "7zip",
  "installer": {
    "script": [
      "& 7z x \"$dir\\$fname\" -o\"$dir\" -y | Out-Null",
      "Remove-Item \"$dir\\$fname\" -Force",
      "$exe = Get-ChildItem \"$dir\" -Filter '*.exe' -Recurse | Select-Object -First 1 -ExpandProperty FullName",
      "if ($exe) {",
      "    $target = \"$dir\\MotrixNext.exe\"",
      "    if (Test-Path $exe) { Move-Item $exe $target -Force }",
      "}"
    ]
  },
  "bin": "MotrixNext.exe",
  "shortcuts": [
    [
      "MotrixNext.exe",
      "Motrix Next"
    ]
  ],
  "checkver": {
    "github": "AnInsomniacy/motrix-next"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe"
      }
    },
    "hash": {
      "url": "$baseurl/checksums.sha256"
    }
  }
}
