{
    "version": "1.1.4",
    "description": "Viap - 专业的 Windows 应用存储重定向工具，使用符号链接将 C 盘应用无损迁移到其他磁盘",
    "homepage": "https://github.com/Chunyu33/viap",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Chunyu33/viap/releases/download/v1.1.4/viap_1.1.4_x64-setup.exe",
            "hash": "36583785ed4f90ae29f597f43ed4eae9bf5b35546c47c29debbe0728de0c45db"
        }
    },
    "installer": {
        "script": [
            "& $dir\$fname /S /D=$dir",
            "Remove-Item \"$dir\\$fname\" -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force -ErrorAction SilentlyContinue",
            "$appdata = [Environment]::GetFolderPath('ApplicationData')",
            "$target = Join-Path $appdata 'viap'",
            "$persist = Join-Path $persist_dir 'AppData-Roaming-viap'",
            "if (Test-Path $target -PathType Container) {",
            "    if (-not (Test-Path $persist)) {",
            "        New-Item -ItemType Directory -Path (Split-Path $persist -Parent) -Force | Out-Null",
            "        Move-Item $target $persist -Force",
            "    }",
            "} elseif (-not (Test-Path $persist)) {",
            "    New-Item -ItemType Directory -Path $persist -Force | Out-Null",
            "}",
            "Remove-Item $target -Force -Recurse -ErrorAction SilentlyContinue",
            "New-Item -ItemType Junction -Path $target -Target $persist | Out-Null"
        ]
    },
    "uninstaller": {
        "script": [
            "$appdata = [Environment]::GetFolderPath('ApplicationData')",
            "$target = Join-Path $appdata 'viap'",
            "Remove-Item $target -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "viap.exe",
    "shortcuts": [
        [
            "viap.exe",
            "Viap"
        ]
    ],
    "checkver": {
        "github": "Chunyu33/viap"
    },
