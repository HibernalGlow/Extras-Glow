{
    "version": "1.1.6",
    "description": "Viap - 专业的 Windows 应用存储重定向工具，使用符号链接将 C 盘应用无损迁移到其他磁盘",
    "homepage": "https://github.com/Chunyu33/viap",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Chunyu33/viap/releases/download/v1.1.6/viap_1.1.6_x64-setup.exe#/dl.7z",
            "hash": "b1c4cbcb0342dba2026fbaaaad0ca47df881d9526dbf3dbac5da13ee3cac38d7"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\uninstall.exe\" -Recurse -Force -ErrorAction SilentlyContinue",
        "if (-not (Test-Path \"$dir\\viap.exe\" -PathType Leaf)) { throw 'viap.exe was not found after archive extraction' }",
        "$appData = [Environment]::GetFolderPath('ApplicationData')",
        "$configPath = Join-Path $appData 'viap.json'",
        "$defaultData = Join-Path $appData 'viap'",
        "$persistData = Join-Path $persist_dir 'data'",
        "$sourceData = $defaultData",
        "if (Test-Path $configPath -PathType Leaf) {",
        "    try {",
        "        $configuredData = (Get-Content $configPath -Raw -Encoding UTF8 | ConvertFrom-Json).data_dir",
        "        if (-not [string]::IsNullOrWhiteSpace([string]$configuredData)) { $sourceData = [Environment]::ExpandEnvironmentVariables([string]$configuredData) }",
        "    } catch { warn 'Ignoring an invalid viap.json data-directory pointer' }",
        "}",
        "$sourceFull = [IO.Path]::GetFullPath($sourceData).TrimEnd('\\')",
        "$defaultFull = [IO.Path]::GetFullPath($defaultData).TrimEnd('\\')",
        "$persistFull = [IO.Path]::GetFullPath($persistData).TrimEnd('\\')",
        "$sameDataPath = [StringComparer]::OrdinalIgnoreCase.Equals($sourceFull, $persistFull)",
        "if (Test-Path $persistData -PathType Leaf) { throw \"Viap persist path is not a directory: $persistData\" }",
        "if (-not $sameDataPath -and (Test-Path $sourceData -PathType Container) -and (Test-Path $persistData -PathType Container)) {",
        "    if (Get-ChildItem $persistData -Force | Select-Object -First 1) { throw 'Both the current Viap data directory and Scoop persist directory contain data; refusing to overwrite either one' }",
        "    Remove-Item $persistData -Recurse -Force",
        "}",
        "if (-not (Test-Path $persistData -PathType Container)) {",
        "    New-Item -ItemType Directory -Path $persist_dir -Force | Out-Null",
        "    if (-not $sameDataPath -and (Test-Path $sourceData -PathType Container)) {",
        "        $migratingData = Join-Path $persist_dir 'data.migrating'",
        "        if (Test-Path $migratingData) { throw \"Stale Viap migration directory exists: $migratingData\" }",
        "        & robocopy $sourceData $migratingData /E /COPY:DAT /DCOPY:DAT /XJ /R:2 /W:1 | Out-Null",
        "        $robocopyExit = $LASTEXITCODE",
        "        if ($robocopyExit -ge 8) { throw \"Failed to migrate Viap data (robocopy exit code $robocopyExit)\" }",
        "        Move-Item $migratingData $persistData",
        "        if ([StringComparer]::OrdinalIgnoreCase.Equals($sourceFull, $defaultFull)) { Remove-Item $sourceData -Recurse -Force }",
        "    } else {",
        "        New-Item -ItemType Directory -Path $persistData | Out-Null",
        "    }",
        "}",
        "$pointerJson = @{ data_dir = $persistData } | ConvertTo-Json",
        "$tempConfig = $configPath + '.tmp'",
        "[IO.File]::WriteAllText($tempConfig, $pointerJson, (New-Object Text.UTF8Encoding($false)))",
        "Move-Item $tempConfig $configPath -Force"
    ],
    "persist": "data",
    "bin": "viap.exe",
    "shortcuts": [
        [
            "viap.exe",
            "Viap"
        ]
    ],
    "checkver": {
        "github": "https://github.com/Chunyu33/viap"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Chunyu33/viap/releases/download/v$version/viap_$version_x64-setup.exe#/dl.7z"
            }
        }
    },
    "notes": [
        "Viap 是一款 Tauri 桌面应用，可将 C 盘应用通过符号链接无损迁移到其他磁盘",
        "运行方式: viap 或在开始菜单搜索 'Viap'",
        "数据目录由 %APPDATA%\\viap.json 指向 Scoop persist 目录",
        "",
        "功能特性:",
        "- 一键迁移 C 盘应用到其他磁盘",
        "- 一键恢复，随时迁回原位置",
        "- 智能识别开发者目录（Gradle、Maven、npm/Yarn、Cargo、pip/uv、NuGet、Claude Code、Codex 等）",
        "",
        "注意: 该工具需要管理员权限运行以创建符号链接",
        "请通过 scoop update viap 更新，不要使用应用内更新器"
    ]
}
