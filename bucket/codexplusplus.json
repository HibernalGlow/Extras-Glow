{
    "version": "1.2.28",
    "description": "Enhanced launcher and manager for Codex App.",
    "homepage": "https://github.com/BigPizzaV3/CodexPlusPlus",
    "license": "Unknown",
    "architecture": {
        "64bit": {
            "url": "https://github.com/BigPizzaV3/CodexPlusPlus/releases/download/v1.2.28/CodexPlusPlus-1.2.28-windows-x64-setup.exe",
            "hash": "8ee01676631516cda6574b827a97c53cec3d68a859f69404f76f9343eea0da5b"
        }
    },
    "depends": "7zip",
    "installer": {
        "script": [
            "& 7z x \"$dir\\$fname\" -o\"$dir\" -y | Out-Null",
            "Remove-Item \"$dir\\$fname\" -Force",
            "$main = Get-ChildItem \"$dir\" -Filter 'codex-plus-plus.exe' -Recurse | Select-Object -First 1 -ExpandProperty FullName",
            "$mgr = Get-ChildItem \"$dir\" -Filter 'codex-plus-plus-manager.exe' -Recurse | Select-Object -First 1 -ExpandProperty FullName",
            "if (-not $main) { throw 'codex-plus-plus.exe not found after extraction' }",
            "if (-not $mgr) { throw 'codex-plus-plus-manager.exe not found after extraction' }",
            "if ($main -ne \"$dir\\codex-plus-plus.exe\") { Move-Item $main \"$dir\\codex-plus-plus.exe\" -Force }",
            "if ($mgr -ne \"$dir\\codex-plus-plus-manager.exe\") { Move-Item $mgr \"$dir\\codex-plus-plus-manager.exe\" -Force }"
        ]
    },
    "bin": [
        "codex-plus-plus.exe",
        "codex-plus-plus-manager.exe"
    ],
    "shortcuts": [
        [
            "codex-plus-plus.exe",
            "Codex++"
        ],
        [
            "codex-plus-plus-manager.exe",
            "Codex++ Manager"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/BigPizzaV3/CodexPlusPlus/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BigPizzaV3/CodexPlusPlus/releases/download/v$version/CodexPlusPlus-$version-windows-x64-setup.exe"
            }
        }
    }
}
