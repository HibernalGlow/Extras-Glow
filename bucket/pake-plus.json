{
  "version": "2.1.8",
  "description": "PakePlus - A tool to convert any website into a desktop app.",
  "homepage": "https://github.com/Sjj1024/PakePlus",
  "license": "MIT",
  "noextract": true,
  "architecture": {
    "64bit": {
      "url": "https://github.com/Sjj1024/PakePlus/releases/download/v2.1.8/PakePlus_2.1.8_x64-setup.exe",
      "hash": "233d56e2cc5104408e145481a704fcbc48ebebb5b9f0b3f2817dd93fa054013e"
    }
  },
  "depends": "7zip",
  "installer": {
    "script": [
      "& 7z x \"$dir\\$fname\" -o\"$dir\" -y | Out-Null",
      "$exe = Get-ChildItem -Path $dir -Filter \"*setup*.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
      "if ($exe) { & 7z x $exe.FullName -o\"$dir\" -y | Out-Null; Remove-Item -Path $exe.FullName -Force }",
      "Remove-Item -Path \"$dir\\$fname\" -Force"
    ]
  },
  "bin": "PakePlus.exe",
  "shortcuts": [
    [
      "PakePlus.exe",
      "PakePlus"
    ]
  ],
  "checkver": {
    "github": "Sjj1024/PakePlus"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/Sjj1024/PakePlus/releases/download/v$version/PakePlus_$version_x64-setup.exe"
      }
    }
  }
}
