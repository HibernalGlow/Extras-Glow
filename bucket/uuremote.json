    "hash": "0d9720d0b9048ea279dd88f4ebf13462f2da8e63a9658c2e285fe46e89d37fe1",
    "installer": {
        "script": [
            "Start-Process -FilePath \"$dir\\$fname\" -ArgumentList \"/S /D=$dir\" -Wait",
            "Remove-Item \"$dir\\$fname\""
        ]
    },
    "bin": "GameViewer\\GameViewer.exe",
    "shortcuts": [
        [
            "GameViewer\\GameViewer.exe",
            "UU Remote"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/n/NetEase/UURemote",
        "jsonpath": "$[*].name",
        "regex": "([\\d.]+)",
        "reverse": true
    },
    "autoupdate": {
        "url": "$match1",
        "hash": {
            "url": "https://raw.githubusercontent.com/microsoft/winget-pkgs/master/manifests/n/NetEase/UURemote/$version/NetEase.UURemote.installer.yaml",
            "regex": "InstallerUrl:\\s+(https://[^\\s]+\\.exe)[\\s\\S]*?InstallerSha256:\\s+([A-Fa-f0-9]{64})"
        }
    }
}
